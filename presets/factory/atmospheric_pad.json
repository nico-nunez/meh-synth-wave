{
  "version": 1,
  "metadata": {
    "name": "Atmospheric Pad",
    "author": "",
    "category": "Pad",
    "description": "Lush evolving pad — detuned oscillators, unison stereo spread, slow LFO scan modulation, long envelopes"
  },
  "oscillators": {
    "osc1": {
      "bank": "sine_to_saw", "scanPos": 0.3, "mixLevel": 1.0,
      "fmDepth": 0.0, "fmRatio": 1.0, "fmSource": "none",
      "octaveOffset": 0, "detuneAmount": 6.0, "enabled": true
    },
    "osc2": {
      "bank": "sine_to_saw", "scanPos": 0.3, "mixLevel": 0.8,
      "fmDepth": 0.0, "fmRatio": 1.0, "fmSource": "none",
      "octaveOffset": 0, "detuneAmount": -6.0, "enabled": true
    },
    "osc3": {
      "bank": "triangle", "scanPos": 0.0, "mixLevel": 0.5,
      "fmDepth": 0.0, "fmRatio": 1.0, "fmSource": "none",
      "octaveOffset": 1, "detuneAmount": 3.0, "enabled": true
    },
    "osc4": {
      "bank": "sine", "scanPos": 0.0, "mixLevel": 0.4,
      "fmDepth": 0.0, "fmRatio": 1.0, "fmSource": "none",
      "octaveOffset": -1, "detuneAmount": 0.0, "enabled": true
    },
    "noise": { "mixLevel": 0.0, "type": "white", "enabled": false }
  },
  "envelopes": {
    "ampEnv": {
      "attackMs": 800.0, "decayMs": 1000.0, "sustainLevel": 0.85,
      "releaseMs": 3000.0, "attackCurve": -4.0, "decayCurve": -3.0, "releaseCurve": -4.0
    },
    "filterEnv": {
      "attackMs": 1200.0, "decayMs": 2000.0, "sustainLevel": 0.4,
      "releaseMs": 2000.0, "attackCurve": -3.0, "decayCurve": -4.0, "releaseCurve": -4.0
    },
    "modEnv": {
      "attackMs": 10.0, "decayMs": 100.0, "sustainLevel": 0.7,
      "releaseMs": 200.0, "attackCurve": -5.0, "decayCurve": -5.0, "releaseCurve": -5.0
    }
  },
  "filters": {
    "svf": { "mode": "lp", "cutoff": 3000.0, "resonance": 0.2, "enabled": true },
    "ladder": { "cutoff": 1000.0, "resonance": 0.3, "drive": 1.0, "enabled": false }
  },
  "bpm": 120.0,
  "lfos": {
    "lfo1": { "bank": "sine", "rate": 0.15, "amplitude": 0.7, "retrigger": false, "tempoSync": false, "subdivision": "1/4" },
    "lfo2": { "bank": "triangle", "rate": 0.08, "amplitude": 0.5, "retrigger": false, "tempoSync": false, "subdivision": "1/4" },
    "lfo3": { "bank": "sine", "rate": 1.0, "amplitude": 1.0, "retrigger": false, "tempoSync": false, "subdivision": "1/4" }
  },
  "modMatrix": [
    { "source": "filterEnv", "destination": "svf.cutoff", "amount": 1.5 },
    { "source": "lfo1", "destination": "osc1.scanPos", "amount": 0.4 },
    { "source": "lfo1", "destination": "osc2.scanPos", "amount": 0.4 },
    { "source": "lfo2", "destination": "svf.cutoff", "amount": 0.3 }
  ],
  "signalChain": ["svf", "ladder", "saturator"],
  "fxChain": ["distortion", "chorus", "phaser", "delay", "reverb"],
  "fx": {
    "distortion": { "drive": 1.0, "mix": 1.0, "type": "soft", "enabled": false },
    "chorus":     { "rate": 0.2, "depth": 0.3, "mix": 0.18, "feedback": 0.0, "enabled": true },
    "phaser":     { "stages": 6, "rate": 0.1, "depth": 0.7, "feedback": 0.35, "mix": 0.25, "enabled": true },
    "delay":      { "time": 0.5, "tempoSync": true, "subdivision": "1/4", "feedback": 0.4, "damping": 0.0, "hpDamping": 0.0, "pingPong": false, "mix": 0.5, "enabled": false },
    "reverb":     { "preDelay": 20.0, "decay": 7.0, "damping": 0.35, "lowDamping": 0.15, "diffusion": 0.88, "bandwidth": 0.8, "modRate": 0.25, "modDepth": 0.4, "mix": 0.35, "enabled": true }
  },
  "voice": {
    "saturator": { "drive": 1.0, "mix": 1.0, "enabled": false },
    "mono": { "enabled": false, "legato": true },
    "portamento": { "time": 50.0, "legato": true, "enabled": false },
    "unison": { "voices": 4, "detune": 15.0, "spread": 0.7, "enabled": true },
    "pitchBend": { "range": 2.0 }
  }
}
