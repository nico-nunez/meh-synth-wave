{
  "version": 1,
  "metadata": {
    "name": "FM Bell",
    "author": "",
    "category": "Keys",
    "description": "Bright metallic bell — FM synthesis with high ratio modulator, fast decay, no sustain"
  },
  "oscillators": {
    "osc1": {
      "bank": "sine", "scanPos": 0.0, "mixLevel": 1.0,
      "fmDepth": 1.8, "fmRatio": 1.0, "fmSource": "osc2",
      "octaveOffset": 0, "detuneAmount": 0.0, "enabled": true
    },
    "osc2": {
      "bank": "sine", "scanPos": 0.0, "mixLevel": 0.0,
      "fmDepth": 0.0, "fmRatio": 3.5, "fmSource": "none",
      "octaveOffset": 0, "detuneAmount": 0.0, "enabled": true
    },
    "osc3": {
      "bank": "sine", "scanPos": 0.0, "mixLevel": 0.25,
      "fmDepth": 0.6, "fmRatio": 7.0, "fmSource": "osc2",
      "octaveOffset": 1, "detuneAmount": 0.0, "enabled": true
    },
    "osc4": {
      "bank": "sine", "scanPos": 0.0, "mixLevel": 0.0,
      "fmDepth": 0.0, "fmRatio": 1.0, "fmSource": "none",
      "octaveOffset": 0, "detuneAmount": 0.0, "enabled": false
    },
    "noise": { "mixLevel": 0.0, "type": "white", "enabled": false }
  },
  "envelopes": {
    "ampEnv": {
      "attackMs": 1.0, "decayMs": 2000.0, "sustainLevel": 0.0,
      "releaseMs": 1500.0, "attackCurve": -1.0, "decayCurve": -6.0, "releaseCurve": -5.0
    },
    "filterEnv": {
      "attackMs": 10.0, "decayMs": 100.0, "sustainLevel": 0.7,
      "releaseMs": 200.0, "attackCurve": -5.0, "decayCurve": -5.0, "releaseCurve": -5.0
    },
    "modEnv": {
      "attackMs": 1.0, "decayMs": 800.0, "sustainLevel": 0.0,
      "releaseMs": 500.0, "attackCurve": -1.0, "decayCurve": -7.0, "releaseCurve": -5.0
    }
  },
  "filters": {
    "svf": { "mode": "lp", "cutoff": 1000.0, "resonance": 0.5, "enabled": false },
    "ladder": { "cutoff": 1000.0, "resonance": 0.3, "drive": 1.0, "enabled": false }
  },
  "bpm": 120.0,
  "lfos": {
    "lfo1": { "bank": "sine", "rate": 1.0, "amplitude": 1.0, "retrigger": false, "tempoSync": false, "subdivision": "1/4" },
    "lfo2": { "bank": "sine", "rate": 1.0, "amplitude": 1.0, "retrigger": false, "tempoSync": false, "subdivision": "1/4" },
    "lfo3": { "bank": "sine", "rate": 1.0, "amplitude": 1.0, "retrigger": false, "tempoSync": false, "subdivision": "1/4" }
  },
  "modMatrix": [
    { "source": "modEnv", "destination": "osc1.fmDepth", "amount": 1.5 }
  ],
  "signalChain": ["svf", "ladder", "saturator"],
  "fxChain": ["distortion", "chorus", "phaser", "delay", "reverb"],
  "fx": {
    "distortion": { "drive": 1.0, "mix": 1.0, "type": "soft", "enabled": false },
    "chorus":     { "rate": 1.0, "depth": 0.5, "mix": 0.5, "feedback": 0.0, "enabled": false },
    "phaser":     { "stages": 4, "rate": 0.5, "depth": 1.0, "feedback": 0.5, "mix": 0.5, "enabled": false },
    "delay":      { "time": 0.5, "tempoSync": true, "subdivision": "1/4", "feedback": 0.3, "damping": 0.45, "hpDamping": 0.05, "pingPong": true, "mix": 0.2, "enabled": true },
    "reverb":     { "preDelay": 10.0, "decay": 4.0, "damping": 0.3, "lowDamping": 0.3, "diffusion": 0.8, "bandwidth": 0.85, "modRate": 0.3, "modDepth": 0.25, "mix": 0.3, "enabled": true }
  },
  "voice": {
    "saturator": { "drive": 1.0, "mix": 1.0, "enabled": false },
    "mono": { "enabled": false, "legato": true },
    "portamento": { "time": 50.0, "legato": true, "enabled": false },
    "unison": { "voices": 4, "detune": 20.0, "spread": 0.5, "enabled": false },
    "pitchBend": { "range": 2.0 }
  }
}
